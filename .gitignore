# Ignore Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude .terraform directory
.terraform/

# Ignore override files
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore sensitive files
secrets.auto.tfvars

# Ignore backup files
*.backup
*.bak
*.tmp

# Ignore IDE/editor files
.vscode/
.idea/
.DS_Store
